{
  "name": "@korphere/oasis-react",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.tsx --format esm,cjs --dts",
    "dev": "tsdown src/index.tsx --format esm --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@korphere/oasis-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "tsdown": "latest",
    "typescript": "latest"
  }
}