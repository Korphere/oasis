{
  "name": "@korphere/oasis-core",
  "version": "0.0.1",
  "license": "MIT",
  "description": "A library to detect user's OS and provide optimal download links for software distribution",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "dev": "tsdown src/index.ts --format esm --watch"
  },
  "devDependencies": {
    "tsdown": "latest",
    "typescript": "latest"
  }
}